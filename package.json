{
  "name": "skillogue-web",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@date-fns/tz": "^1.4.1",
    "@dicebear/collection": "^9.2.3",
    "@dicebear/core": "^9.2.3",
    "@hookform/resolvers": "^5.2.2",
    "appwrite": "^24.2.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "lucide-react": "^0.536.0",
    "next": "^16.0.10",
    "node-appwrite": "^24.0.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.62.0",
    "react-hot-toast": "^2.6.0",
    "zod": "^4.0.14"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "appwrite:setup-db": "node scripts/setup-appwrite-db.mjs",
    "appwrite:seed-demo-data": "node scripts/seed-appwrite-demo-data.js",
    "appwrite:normalize-profile-genders": "node scripts/normalize-profile-genders.js",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "test": "jest",
    "test:all": "node scripts/run-all-tests.js",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "E2E_MODE=1 npm run build -- --webpack && PLAYWRIGHT_COLLECT_COVERAGE=1 PLAYWRIGHT_WEB_SERVER_COMMAND=\"env NODE_V8_COVERAGE=.v8-coverage NODE_OPTIONS=--inspect=9330 npm run start\" playwright test --project=desktop-chrome",
    "coverage:jest": "npm test -- --runInBand --watch=false --coverage",
    "coverage:merge": "nextcov merge coverage coverage/e2e -o coverage/merged",
    "coverage:all": "npm run coverage:jest && npm run test:e2e:coverage && npm run coverage:merge",
    "test:e2e:admin-command-center": "PLAYWRIGHT_SKIP_WEB_SERVER=1 BASE_URL=http://localhost:3000 playwright test __tests__/e2e/admin.spec.ts --project=desktop-chrome --grep \"allowlisted admin\" --reporter=line --workers=1",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@opennextjs/cloudflare": "^1.19.5",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.12",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.10",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.9",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "nextcov": "^1.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "wrangler": "^4.87.0"
  },
  "overrides": {
    "glob": "10.5.0"
  }
}
